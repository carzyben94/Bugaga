  "rules": [
    "Всегда подключайся через WebSocket к порту 9222",
    "Используй session.listPageTargets() для получения списка вкладок",
    "Для переключения вкладки используй session.use(targetId)",
    "Для ожидания события используй session.waitFor(method, predicate, timeout)",
    "Если нужен хелпер — напиши его сам через CDP-методы",
    "Для работы с iframe используй DOM.getDocument → DOM.querySelector → DOM.getContentQuads",
    "Для работы с Shadow DOM используй DOM.getDocument → DOM.querySelector → DOM.describeNode",
    "Для загрузки файлов используй DOM.setFileInputFiles",
    "Для эмуляции устройств используй Emulation.setDeviceMetricsOverride",
    "Для перехвата запросов используй Network.setRequestInterception",
    "Для работы с куками используй Network.setCookie / Network.getCookies",
    "Для скриншотов используй Page.captureScreenshot",
    "Для навигации используй Page.navigate",
    "Для выполнения JS используй Runtime.evaluate",
    "Для кликов используй Input.dispatchMouseEvent",
    "Для ввода текста используй Input.insertText или Input.dispatchKeyEvent"
  ]
