{
  "name": "x_com_extraction",
  "version": "1.0.0",
  "description": "Модели для извлечения данных из X.com (Twitter)",
  "site": "x.com",
  "error_handling": {
    "not_found": {"action": "return_empty", "message": "Элемент не найден"},
    "login_required": {"action": "use_cookies", "message": "Требуется авторизация"},
    "timeout": {"action": "retry", "max_retries": 3, "delay": 2000}
  },
  "pagination": {
    "enabled": true,
    "method": "scroll",
    "max_scrolls": 5,
    "wait_between_scrolls": 2000
  },
  "models": {
    "profile": {
      "description": "Извлечение профиля пользователя",
      "fields": {
        "name": {
          "selector": "div[data-testid='User-Name'] span",
          "description": "Имя пользователя"
        },
        "username": {
          "selector": "div[data-testid='User-Name'] span:last-child",
          "description": "Username (@handle)"
        },
        "bio": {
          "selector": "div[data-testid='UserDescription']",
          "description": "Биография"
        },
        "location": {
          "selector": "span[data-testid='UserLocation']",
          "description": "Местоположение"
        },
        "avatar": {
          "selector": "img[alt*='avatar']",
          "description": "Аватар"
        },
        "followers": {
          "selector": "a[href$='/followers'] span[data-testid='userFollowCount']",
          "transform": "int",
          "description": "Количество подписчиков"
        },
        "following": {
          "selector": "a[href$='/following'] span[data-testid='userFollowCount']",
          "transform": "int",
          "description": "Количество подписок"
        },
        "posts_count": {
          "selector": "a[href$='/with_replies'] span",
          "transform": "int",
          "description": "Количество постов"
        },
        "joined_date": {
          "selector": "span[data-testid='UserJoinDate']",
          "description": "Дата регистрации"
        },
        "is_blue": {
          "selector": "svg[aria-label*='Verified']",
          "transform": "exists",
          "description": "Синяя галочка"
        },
        "website": {
          "selector": "a[data-testid='UserWebsite']",
          "description": "Сайт пользователя"
        }
      }
    },
    "tweet": {
      "description": "Извлечение одного твита",
      "selector": "article[data-testid='tweet']",
      "fields": {
        "id": {
          "selector": "a[href*='/status/']",
          "transform": "extract_tweet_id",
          "description": "ID твита"
        },
        "text": {
          "selector": "div[data-testid='tweetText']",
          "description": "Текст твита"
        },
        "author_name": {
          "selector": "div[data-testid='User-Name'] span",
          "description": "Имя автора"
        },
        "author_username": {
          "selector": "div[data-testid='User-Name'] span:last-child",
          "description": "Username автора"
        },
        "timestamp": {
          "selector": "time[datetime]",
          "description": "Время публикации"
        },
        "likes": {
          "selector": "button[data-testid='like'] span",
          "transform": "int",
          "description": "Лайки"
        },
        "retweets": {
          "selector": "button[data-testid='retweet'] span",
          "transform": "int",
          "description": "Ретвиты"
        },
        "replies": {
          "selector": "button[data-testid='reply'] span",
          "transform": "int",
          "description": "Ответы"
        },
        "views": {
          "selector": "span[data-testid='views']",
          "transform": "int",
          "description": "Просмотры"
        },
        "media": {
          "selector": "div[data-testid='tweetPhoto'] img",
          "transform": "list",
          "description": "Изображения"
        }
      }
    },
    "tweets_list": {
      "description": "Извлечение списка твитов",
      "container": "article[data-testid='tweet']",
      "item_model": "tweet",
      "limit": 20,
      "pagination": true
    },
    "search_result": {
      "description": "Результаты поиска",
      "container": "article[data-testid='tweet']",
      "item_model": "tweet",
      "limit": 50,
      "pagination": true
    },
    "trends": {
      "description": "Извлечение трендов",
      "container": "div[data-testid='trend']",
      "fields": {
        "name": {
          "selector": "span",
          "description": "Название тренда"
        },
        "tweet_count": {
          "selector": "span:last-child",
          "transform": "int",
          "description": "Количество твитов"
        },
        "url": {
          "selector": "a[href*='/explore/']",
          "description": "Ссылка на тренд"
        }
      }
    }
  },
  "transformers": {
    "extract_tweet_id": {
      "code": "lambda url: url.split('/status/')[-1].split('?')[0] if url else None"
    },
    "int": {
      "code": "lambda x: int(x.replace(',', '')) if x else 0"
    },
    "exists": {
      "code": "lambda x: True if x else False"
    },
    "list": {
      "code": "lambda x: [x] if x else []"
    }
  }
}